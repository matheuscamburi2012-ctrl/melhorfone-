---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

const posts = [
  { title: "iPhone 15 vs Samsung Galaxy S24: Qual é Melhor?", excerpt: "Confronto completo entre os dois flagships mais populares.", image: "https://images.unsplash.com/photo-1592750475338-74b7b21085ab?w=600&h=338&fit=crop", category: "Comparativo", date: "3 Jun 2025", slug: "iphone-15-vs-samsung-galaxy-s24", stars: 5 },
  { title: "Melhores Celulares para Fotografia 2025", excerpt: "iPhone 15 lidera no quesito vídeo e qualidade de imagem.", image: "https://images.unsplash.com/photo-1516035069371-29a1b244cc32?w=600&h=338&fit=crop", category: "Guia de Compra", date: "5 Jun 2025", slug: "melhores-celulares-fotografia-2025", stars: 5 },
];
---

<BaseLayout title="iPhone 2025 — Reviews e Comparativos" description="Reviews e comparativos dos iPhones disponíveis no Brasil em 2025. Vale a pena comprar?">
  <div class="container" style="padding:32px 0">
    <nav class="breadcrumb">
      <a href="/">Home</a> <span>›</span> <span>iPhone</span>
    </nav>
    <h1 class="section-title" style="font-size:1.6rem;margin-bottom:8px">📱 iPhone</h1>
    <p style="color:var(--text-muted);margin-bottom:28px">Reviews e comparativos dos iPhones disponíveis no Brasil</p>
    <div class="grid-3">
      {posts.map(post => <PostCard {...post} />)}
    </div>
  </div>
</BaseLayout>
