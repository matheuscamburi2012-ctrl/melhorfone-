---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

const posts = [
  { title: "Xiaomi Redmi Note 13 Pro Review", excerpt: "Câmera de 200MP que realmente impressiona? Testamos por 30 dias.", image: "https://images.unsplash.com/photo-1574944985070-8f3ebc6b79d2?w=600&h=338&fit=crop", category: "Review", date: "16 Jun 2025", slug: "xiaomi-redmi-note-13-pro-review", stars: 5 },
  { title: "Melhores Celulares até R$ 1.000 em 2025", excerpt: "O Redmi Note 13 lidera o ranking de custo-benefício.", image: "https://images.unsplash.com/photo-1585060544812-6b45742d762f?w=600&h=338&fit=crop", category: "Guia de Compra", date: "8 Jun 2025", slug: "melhores-celulares-ate-1000-reais", stars: 5 },
  { title: "Melhores Celulares para Fotografia 2025", excerpt: "Redmi Note 13 Pro com 200MP é destaque na lista.", image: "https://images.unsplash.com/photo-1516035069371-29a1b244cc32?w=600&h=338&fit=crop", category: "Guia de Compra", date: "5 Jun 2025", slug: "melhores-celulares-fotografia-2025", stars: 5 },
];
---

<BaseLayout title="Celulares Xiaomi 2025 — Reviews e Guias" description="Reviews e guias dos melhores celulares Xiaomi e Redmi disponíveis no Brasil em 2025.">
  <div class="container" style="padding:32px 0">
    <nav class="breadcrumb">
      <a href="/">Home</a> <span>›</span> <span>Xiaomi</span>
    </nav>
    <h1 class="section-title" style="font-size:1.6rem;margin-bottom:8px">📱 Celulares Xiaomi</h1>
    <p style="color:var(--text-muted);margin-bottom:28px">Reviews e guias dos melhores Xiaomi e Redmi disponíveis no Brasil</p>
    <div class="grid-3">
      {posts.map(post => <PostCard {...post} />)}
    </div>
  </div>
</BaseLayout>
