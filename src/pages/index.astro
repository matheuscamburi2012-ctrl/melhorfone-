    amazonUrl: "#",
    mlUrl: "#",
    badge: "Mais Vendido",
  },
  {
    title: "Motorola Moto G84 5G 256GB — pOLED 120Hz + 50MP",
    image: "https://http2.mlstatic.com/D_NQ_NP_771036-MLA71992506512_092023-O.webp",
    price: "R$ 1.199",
    originalPrice: "R$ 1.499",
    stars: 4,
    reviews: 1523,
    amazonUrl: "#",
    mlUrl: "#",
    badge: "5G",
  },
  {
    title: "Samsung Galaxy A54 5G 256GB — Super AMOLED 120Hz",
