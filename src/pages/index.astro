---

<BaseLayout
  title="Melhores Celulares 2025"
  description="Guia completo de smartphones: comparativos, reviews e as melhores ofertas na Amazon e Mercado Livre."
>

  <!-- HERO -->
  <section class="hero-banner">
    <h1>Encontre o Celular Perfeito pelo Melhor Preço</h1>
    <p>Comparativos, reviews e guias de compra para te ajudar a escolher o smartphone ideal na Amazon e Mercado Livre.</p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
      <a href="/melhores" class="btn btn-primary">Ver Melhores Celulares</a>
      <a href="/comparativos" class="btn btn-outline">Comparar Modelos</a>
    </div>
  </section>

  <!-- DESTAQUES -->
  <section class="main-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">⭐ Destaques</h2>
        <a href="/celulares" class="see-all">Ver todos →</a>
      </div>
      <div class="featured-grid">
        {featuredPosts.map(post => <PostCard {...post} />)}
      </div>
    </div>
  </section>

  <!-- PRODUTOS EM OFERTA -->
  <section class="main-section" style="background:var(--bg-white);padding:32px 0">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">🔥 Mais Bem Avaliados</h2>
        <a href="/melhores" class="see-all">Ver mais →</a>
      </div>
      <div class="grid-4">
        {topProducts.map(product => <ProductCard {...product} />)}
      </div>
    </div>
  </section>

  <!-- CTA WHATSAPP -->
  <div class="container">
    <div class="cta-whatsapp">
      <h2>📱 Grupo de Ofertas de Celulares</h2>
      <p>Receba as melhores ofertas de smartphones diretamente no seu WhatsApp antes que acabem!</p>
      <a href="https://wa.me/seu-numero" target="_blank" rel="noopener" class="btn btn-whatsapp">
        Entrar no Grupo Gratuito
      </a>
    </div>
  </div>

  <!-- POSTS RECENTES -->
  <section class="main-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">🆕 Publicações Recentes</h2>
        <a href="/celulares" class="see-all">Ver todos →</a>
      </div>
      <div class="grid-4">
        {recentPosts.map(post => <PostCard {...post} />)}
      </div>
    </div>
  </section>

  <!-- CATEGORIAS -->
  <section class="main-section" style="background:var(--bg-white);padding:32px 0">
    <div class="container">
      <h2 class="section-title">📂 Navegar por Categoria</h2>
      <div class="grid-4" style="gap:12px">
        {[
          { icon: "💰", label: "Até R$ 500", href: "/preco/ate-500" },
          { icon: "📊", label: "Até R$ 1.000", href: "/preco/ate-1000" },
          { icon: "🏆", label: "Premium", href: "/preco/premium" },
          { icon: "📸", label: "Melhor Câmera", href: "/categoria/camera" },
          { icon: "🔋", label: "Melhor Bateria", href: "/categoria/bateria" },
          { icon: "⚡", label: "Melhor Desempenho", href: "/categoria/desempenho" },
          { icon: "5G", label: "Com 5G", href: "/categoria/5g" },
          { icon: "📱", label: "Tela Grande", href: "/categoria/tela-grande" },
        ].map(cat => (
          <a href={cat.href} class="cat-card">
            <div class="cat-icon">{cat.icon}</div>
            {cat.label}
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.cat-card {
  background: var(--bg);
  border-radius: var(--radius);
  padding: 20px;
  text-align: center;
  font-weight: 700;
  font-size: .9rem;
  transition: all .2s;
  border: 2px solid var(--border);
  display: block;
  color: var(--text);
}
.cat-card:hover { border-color: var(--primary); color: var(--primary); background: #fff5f5; transform: translateY(-2px); }
.cat-icon { font-size: 1.5rem; margin-bottom: 6px; }
</style>
