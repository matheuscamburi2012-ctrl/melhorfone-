---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

const posts = [
  { title: "10 Melhores Celulares Custo-Benefício de 2025", excerpt: "Selecionamos os melhores smartphones para cada faixa de preço.", image: "https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?w=600&h=338&fit=crop", category: "Guia de Compra", date: "12 Jun 2025", slug: "melhores-celulares-custo-beneficio-2025", stars: 5 },
  { title: "Samsung Galaxy A55 Review: Vale o Preço?", excerpt: "Testamos o A55 por 30 dias. Confira nossa análise completa.", image: "https://images.unsplash.com/photo-1610945415295-d9bbf067e59c?w=600&h=338&fit=crop", category: "Review", date: "7 Jun 2025", slug: "samsung-galaxy-a55-review", stars: 4 },
  { title: "Melhores Celulares Samsung 2025", excerpt: "Do Galaxy A15 ao S24 Ultra: qual Samsung comprar em 2025?", image: "https://images.unsplash.com/photo-1610945264803-c22b62d2a7b3?w=600&h=338&fit=crop", category: "Guia de Compra", date: "16 Jun 2025", slug: "melhores-celulares-samsung-2025", stars: 5 },
  { title: "Melhores Celulares até R$ 1.000 em 2025", excerpt: "Os melhores smartphones para quem quer qualidade sem gastar muito.", image: "https://images.unsplash.com/photo-1585060544812-6b45742d762f?w=600&h=338&fit=crop", category: "Guia de Compra", date: "8 Jun 2025", slug: "melhores-celulares-ate-1000-reais", stars: 5 },
  { title: "Melhores Celulares para Fotografia 2025", excerpt: "Câmeras incríveis por preços acessíveis.", image: "https://images.unsplash.com/photo-1617778668659-ce80c9bcc93e?w=600&h=338&fit=crop", category: "Guia de Compra", date: "5 Jun 2025", slug: "melhores-celulares-fotografia-2025", stars: 5 },
  { title: "Celular com Melhor Bateria 2025: Top 8", excerpt: "Os celulares com maior autonomia disponíveis no Brasil.", image: "https://images.unsplash.com/photo-1565849904461-04a58ad377e0?w=600&h=338&fit=crop", category: "Guia de Compra", date: "1 Jun 2025", slug: "celular-melhor-bateria-2025", stars: 4 },
  { title: "iPhone 15 vs Samsung Galaxy S24: Qual é Melhor?", excerpt: "Confronto completo entre os dois flagships mais populares.", image: "https://images.unsplash.com/photo-1592750475338-74b7b21085ab?w=600&h=338&fit=crop", category: "Comparativo", date: "3 Jun 2025", slug: "iphone-15-vs-samsung-galaxy-s24", stars: 5 },
  { title: "Motorola Moto G84 5G: Review Completo 2025", excerpt: "Tela pOLED, 256GB e carregador 33W na caixa. Vale a pena?", image: "https://images.unsplash.com/photo-1598327105666-5b89351aff97?w=600&h=338&fit=crop", category: "Review", date: "16 Jun 2025", slug: "motorola-moto-g84-review", stars: 4 },
  { title: "Melhores Celulares para Jogos 2025", excerpt: "Top 6 smartphones gamer para Free Fire, PUBG e Genshin.", image: "https://images.unsplash.com/photo-1511512578047-dfb367046420?w=600&h=338&fit=crop", category: "Guia de Compra", date: "16 Jun 2025", slug: "melhores-celulares-para-jogos-2025", stars: 5 },
  { title: "Xiaomi Redmi Note 13 Pro Review", excerpt: "Câmera de 200MP que realmente impressiona? Testamos por 30 dias.", image: "https://images.unsplash.com/photo-1512499617640-c2f999098c01?w=600&h=338&fit=crop", category: "Review", date: "16 Jun 2025", slug: "xiaomi-redmi-note-13-pro-review", stars: 5 },
  { title: "Melhores Celulares 5G até R$ 2.000", excerpt: "5G acessível: os melhores smartphones com conectividade 5G.", image: "https://images.unsplash.com/photo-1580910051074-3eb694886505?w=600&h=338&fit=crop", category: "Guia de Compra", date: "16 Jun 2025", slug: "melhores-celulares-5g-ate-2000-reais", stars: 5 },
];
---

<BaseLayout title="Celulares" description="Todos os guias, reviews e comparativos de smartphones.">
  <div class="container" style="padding:32px 0">
    <nav class="breadcrumb">
      <a href="/">Home</a> <span>›</span> <span>Celulares</span>
    </nav>
    <h1 class="section-title" style="font-size:1.6rem;margin-bottom:28px">📱 Celulares</h1>

    <!-- Filtros rápidos -->
    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:28px">
      <a href="/celulares" class="tag" style="padding:6px 14px">Todos</a>
      <a href="/comparativos" class="tag" style="padding:6px 14px">Comparativos</a>
      <a href="/custo-beneficio" class="tag" style="padding:6px 14px">Custo-Benefício</a>
      <a href="/marca/samsung" class="tag" style="padding:6px 14px">Samsung</a>
      <a href="/marca/xiaomi" class="tag" style="padding:6px 14px">Xiaomi</a>
      <a href="/marca/motorola" class="tag" style="padding:6px 14px">Motorola</a>
      <a href="/marca/iphone" class="tag" style="padding:6px 14px">iPhone</a>
    </div>

    <div class="grid-4">
      {posts.map(post => <PostCard {...post} />)}
    </div>

    <div class="pagination">
      <span class="active">1</span>
      <a href="?p=2">2</a>
      <a href="?p=3">3</a>
      <a href="?p=4">4</a>
      <span>…</span>
      <a href="?p=10">10</a>
    </div>
  </div>
</BaseLayout>
