---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

const comparativos = [
  { title: "Xiaomi Redmi Note 13 vs Motorola Moto G84: Qual Comprar?", excerpt: "Comparamos câmera, bateria, desempenho e preço dos dois intermediários mais vendidos.", image: "/images/placeholder-wide.jpg", category: "Comparativo", date: "10 Jun 2025", slug: "xiaomi-redmi-note-13-vs-motorola-moto-g84" },
  { title: "iPhone 15 vs Samsung Galaxy S24: Qual é Melhor?", excerpt: "Confronto completo entre os dois flagships mais populares do mercado em 2025.", image: "/images/placeholder-wide.jpg", category: "Comparativo", date: "3 Jun 2025", slug: "iphone-15-vs-samsung-galaxy-s24" },
  { title: "Samsung Galaxy A55 vs A54: Mudou Muita Coisa?", excerpt: "Vale a pena atualizar do A54 para o A55? Veja o que mudou.", image: "/images/placeholder-wide.jpg", category: "Comparativo", date: "28 Mai 2025", slug: "samsung-galaxy-a55-vs-a54" },
  { title: "Poco X6 vs Xiaomi Redmi Note 13 Pro: Qual Ganha?", excerpt: "Dois Xiaomi no confronto: qual tem melhor custo-benefício?", image: "/images/placeholder-wide.jpg", category: "Comparativo", date: "20 Mai 2025", slug: "poco-x6-vs-xiaomi-redmi-note-13-pro" },
];
---

<BaseLayout title="Comparativos de Celulares 2025" description="Compare smartphones lado a lado e escolha o melhor para você.">
  <div class="container" style="padding:32px 0">
    <nav class="breadcrumb">
      <a href="/">Home</a> <span>›</span> <span>Comparativos</span>
    </nav>
    <h1 class="section-title" style="font-size:1.6rem;margin-bottom:8px">⚖️ Comparativos de Celulares</h1>
    <p style="color:var(--text-muted);margin-bottom:28px">Compare modelos lado a lado e tome a melhor decisão de compra</p>
    <div class="grid-3">
      {comparativos.map(post => <PostCard {...post} />)}
    </div>
  </div>
</BaseLayout>
